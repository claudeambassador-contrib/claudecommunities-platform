# OpenSSL command to generate a random 32-byte string for RENDER_SIGNING_SECRET:
# openssl rand -hex 32

# Region — "au" (default) or "nz". Selects which account/Clerk instance a
# deploy targets. AU deploys use the .env / .env.staging / .env.prod files.
# NZ deploys use the .env.nz.* files and the NZ Cloudflare account's
# CLOUDFLARE_API_TOKEN (run via the `nz:*` npm scripts).
NEXT_PUBLIC_REGION=au

# Public site origin used for canonical URLs, OpenGraph, sitemap and robots.
# Defaults to the AU domain when unset (NZ deploys set the .co.nz origin).
NEXT_PUBLIC_SITE_URL=

# GA4 measurement id. Falls back to the AU property for AU deploys; leave
# unset on NZ until an NZ property exists (analytics is skipped when empty).
NEXT_PUBLIC_GA_ID=

# Optional override for the transactional/campaign email sender. When unset
# the region config's fromEmail is used (AU: claudecommunity.com.au,
# NZ: claudecommunity.co.nz). On the Worker set it as a secret if overriding.
RESEND_FROM_EMAIL=

# Email transport. Default (unset/"resend") sends via Resend. Set to "send16"
# to route all transactional + campaign email through the Send16 "Claude
# Community" workspace instead (reversible — unset to fall back to Resend).
# Requires SEND16_API_KEY and a verified sending domain in that workspace.
EMAIL_PROVIDER=
# sk_live_ key for the Send16 workspace (used by the send16 transport AND the
# scripts/sync-users-to-send16.ts backfill).
SEND16_API_KEY=
# Send16 API origin. Defaults to https://api.send16.com when unset.
SEND16_BASE_URL=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# AI
ANTHROPIC_API_KEY=

# API key for Claudience, used by the worker to proxy requests to the Claudience API.
CLAUDIENCE_API_KEY=

# HMAC secret used to sign URLs handed to Cloudflare Browser Rendering when
# screenshotting slide previews. Any 32+ char random string.
#
# Required on deployments that render slide PNGs. Set as a Worker secret:
#   wrangler secret put RENDER_SIGNING_SECRET --env staging
#   wrangler secret put RENDER_SIGNING_SECRET --env production
RENDER_SIGNING_SECRET=4849be082d169bc1c931e56cea64040e27488945dfe4a490b48531f5e3785593

# Cron — shared secret for /api/cron/* routes. Caller sends x-cron-secret header.
CRON_SECRET=

# Social posting (LinkedIn etc.). Required for /admin/social.
# Create a LinkedIn app at developer.linkedin.com and apply for the
# Community Management API. Redirect URI must be set in the LinkedIn app to:
#   {NEXT_PUBLIC_APP_URL}/api/admin/social/accounts/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# HMAC secret used to sign the OAuth state parameter (CSRF protection).
# Any 32+ char random string — `openssl rand -hex 32`. Only required for
# the direct LinkedIn connector; the Zernio connector doesn't use it.
SOCIAL_OAUTH_STATE_SECRET=

# Optional override for Zernio's REST base URL (e.g. for staging fixtures).
# Leave unset to use the public https://zernio.com/api/v1.
# ZERNIO_API_URL=

# Set to "true" on staging to send every Zernio publish as a draft instead
# of actually posting to LinkedIn. The full publish path still runs — the
# post just lands in your Zernio dashboard for inspection. Safe to flip
# via `wrangler secret put ZERNIO_DRY_RUN --env staging` without redeploy.
# ZERNIO_DRY_RUN=true