# .env.selfhost.example — template for .env.selfhost (committed; no real values).
#
# For SELF-HOSTERS forking this repo onto their OWN, fresh Cloudflare account.
# Copy to .env.selfhost (gitignored) and fill in YOUR values:
#
#   cp .env.selfhost.example .env.selfhost   # then fill in the real values
#
# Render the single generic deployment config from these values:
#   node scripts/gen-wrangler.mjs --template wrangler.selfhost.template.jsonc
#   (or: bun run gen:wrangler:selfhost)
#
# Under Cloudflare Workers Builds set these the same way in the dashboard
# (Settings -> Variables & Secrets) instead of this file. gen-wrangler errors,
# listing every empty token, if any token used by the template is blank.
#
# This is the COMPLETE list of tokens the self-host template references (12).
# Runtime SECRETS (Clerk keys, RESEND_* / SEND16_API_KEY, RENDER_SIGNING_SECRET,
# LINKEDIN_*, SOCIAL_OAUTH_STATE_SECRET) are NOT here — set those with
# `wrangler secret put <NAME>`. See docs/self-hosting.md.

# Your Cloudflare account id (Dashboard -> any domain -> Overview, right sidebar).
CF_ACCOUNT_ID=

# Name for your Worker (lowercase, hyphens). Also used for WORKER_SELF_REFERENCE.
CF_WORKER_NAME=

# D1 primary application database id (DB binding).
#   wrangler d1 create claudecommunity-db  -> copy the printed database_id
CF_D1_ID=

# D1 tag-cache database id (NEXT_TAG_CACHE_D1 binding) — separate D1 database.
#   wrangler d1 create claudecommunity-next-tag-cache  -> copy database_id
CF_D1_TAGCACHE_ID=

# R2 bucket for user uploads (STORAGE binding).
#   wrangler r2 bucket create claudecommunity-uploads  -> use the bucket name
CF_R2_BUCKET=

# R2 bucket for OpenNext incremental cache (NEXT_INC_CACHE_R2_BUCKET binding).
#   wrangler r2 bucket create claudecommunity-next-cache  -> use the bucket name
CF_R2_CACHE_BUCKET=

# Custom-domain route. Must be an Active zone on this account, e.g.
#   community.example.org
CF_ROUTE=

# Public origin URL (drives both NEXT_PUBLIC_APP_URL and NEXT_PUBLIC_SITE_URL),
# e.g. https://community.example.org
CF_PUBLIC_URL=

# Region branding key from src/lib/region.ts ("au" default | "nz"). Stage 3c
# will make branding fully env-driven; for now pick the closest built-in.
NEXT_PUBLIC_REGION=

# Multi-tenancy routing knobs (see docs/multi-tenancy-setup.md).
# Home tenant slug the apex + /admin resolve to (e.g. "platform").
HOME_TENANT=
# Comma-separated hosts treated AS the platform (apex/local/preview),
# e.g. example.org,localhost,127.0.0.1,workers.dev
PLATFORM_HOSTS=
# Comma-separated base host(s) under which *.<base> is read as a tenant
# subdomain, e.g. example.org
TENANT_SUBDOMAIN_BASES=
