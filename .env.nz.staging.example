# =============================================================================
# NZ STAGING environment (TEMPLATE — no real secrets committed)
#
# Holds the New Zealand account's credentials: the NZ Clerk instance keys,
# NZ email/Resend + social config, and the NZ Cloudflare account-scoped API
# token. Used by the `nz:staging:*` npm scripts (--env staging-nz). Fill in
# real values locally / via Worker secrets — do NOT commit secrets.
# =============================================================================

# Region marker — selects NZ vs AU behaviour at runtime.
NEXT_PUBLIC_REGION=nz

# NZ account-scoped Cloudflare API token (used for nz:* deploys).
CLOUDFLARE_API_TOKEN=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# AI
ANTHROPIC_API_KEY=

# API key for Claudience, used by the worker to proxy requests to the Claudience API.
CLAUDIENCE_API_KEY=

# HMAC secret used to sign URLs handed to Cloudflare Browser Rendering when
# screenshotting slide previews. Any 32+ char random string.
#
# Required on deployments that render slide PNGs. Set as a Worker secret:
#   wrangler secret put RENDER_SIGNING_SECRET --env staging-nz
RENDER_SIGNING_SECRET=

# Cron — shared secret for /api/cron/* routes. Caller sends x-cron-secret header.
CRON_SECRET=

# Social posting (LinkedIn etc.). Required for /admin/social.
# Create a LinkedIn app at developer.linkedin.com and apply for the
# Community Management API. Redirect URI must be set in the LinkedIn app to:
#   {NEXT_PUBLIC_APP_URL}/api/admin/social/accounts/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# HMAC secret used to sign the OAuth state parameter (CSRF protection).
# Any 32+ char random string — `openssl rand -hex 32`. Only required for
# the direct LinkedIn connector; the Zernio connector doesn't use it.
SOCIAL_OAUTH_STATE_SECRET=

# Optional override for Zernio's REST base URL (e.g. for staging fixtures).
# Leave unset to use the public https://zernio.com/api/v1.
# ZERNIO_API_URL=

# Set to "true" on staging to send every Zernio publish as a draft instead
# of actually posting to LinkedIn. The full publish path still runs — the
# post just lands in your Zernio dashboard for inspection. Safe to flip
# via `wrangler secret put ZERNIO_DRY_RUN --env staging-nz` without redeploy.
# ZERNIO_DRY_RUN=true
