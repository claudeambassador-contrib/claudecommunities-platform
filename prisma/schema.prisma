// ── Social posting (LinkedIn first, modular for more platforms) ───────────
// SocialAccount stores one OAuth connection per platform target (e.g. one
// LinkedIn company page). SocialPost is the unit of scheduled/sent content.
// See src/lib/social/ for the provider abstraction.

model SocialAccount {
  id           String       @id @default(cuid())
  tenantId     String @default("")
  // Destination network. Stays "linkedin" regardless of how we reach it.
  platform     String
  // Integration used to reach the destination. "linkedin" = direct OAuth +
  // LinkedIn REST API. "zernio" = posts via zernio.com using a Zernio API key.
  // Adding a new connector means registering it in src/lib/social/providers
  // — no schema change required.
  connector    String       @default("linkedin")
  accountType  String       @default("organization") // "organization" | "person"
  // Platform-side ID. For direct LinkedIn: the org id (e.g. "5515715"). For
  // Zernio: the Zernio account `_id` (we route by that, not by LinkedIn org).
  externalId   String
  displayName  String
  avatarUrl    String?
  // For OAuth connectors: the LinkedIn access token. For API-key connectors
  // (Zernio): the Zernio API key. TODO: encrypt at rest.
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scopes       String?
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  posts        SocialPost[]

  @@unique([tenantId, connector, externalId])
  @@index([tenantId, platform])
  @@index([tenantId, connector])
}

model SocialPost {
  id              String        @id @default(cuid())
  tenantId        String @default("")
  accountId       String
  account         SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform        String // denormalised from account for filtering
  content         String
  mediaType       String        @default("none") // "none" | "image" | "multi_image" | "video" | "document"
  mediaUrls       String        @default("[]") // JSON string[]; order matters for multi_image
  status          String        @default("draft") // "draft" | "scheduled" | "publishing" | "published" | "failed" | "cancelled"
  scheduledAt     DateTime?
  publishedAt     DateTime?
  externalId      String? // platform-side URN, e.g. urn:li:share:684...
  externalUrl     String? // public share URL after publish
  errorMessage    String?
  publishAttempts Int           @default(0)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, accountId, scheduledAt])
  @@index([tenantId, platform, status])
}

// ─── Multi-tenant registry & membership ─────────────────────────────────────
// The registry plane. GLOBAL models (Tenant, TenantSetting) are read pre-tenant
// in middleware via the unscoped platform client — the only pre-tenant DB read.
// UserTenant / PendingAdminGrant / AuditLog are TENANT-scoped (carry tenantId),
// so the scoped client auto-injects the URL tenant. See tenant-models.ts.

/// Tenant registry — one row per community. Resolved from URL/host: custom
/// domain → row, else first path segment `claudecommunities.com/<slug>` → row.
model Tenant {
  id           String         @id @default(cuid())
  slug         String         @unique
  customDomain String?        @unique
  name         String
  status       String         @default("active") // active | suspended | pending
  // Whether this community appears in the public platform directory at the apex.
  // A community can be hidden (listed=false) without suspending it (still
  // reachable on its slug / domain). Suspended tenants are never listed.
  listed       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  settings     TenantSetting?
}

/// Admin-editable per-tenant config — replaces the build-baked REGION_CONFIGS.
/// `config` is a JSON blob of the former RegionConfig shape (country, lang,
/// currency, emails, discord, cities, images, …). gaId is broken out so the
/// analytics-egress isolation (§3 #32) can read it directly.
model TenantSetting {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  config       String   @default("{}")
  gaId         String?
  fromEmail    String?
  senderDomain String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // `tenantId` is the tenant SLUG (the scoping label used across all models),
  // not Tenant.id — so this relation references Tenant.slug (also @unique).
  tenant       Tenant   @relation(fields: [tenantId], references: [slug], onDelete: Cascade)
}

/// Membership join. The COARSE per-tenant role (owner|admin|member) lives HERE,
/// never on the global User.role — otherwise admin-in-A = admin-in-B (privesc,
/// §3 #5). Tenant-scoped: getPrisma().userTenant.findFirst({where:{userId}})
/// auto-injects tenantId, returning the row (with role) iff the user belongs to
/// THIS tenant.
model UserTenant {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

/// Admin role granted to an invitee before they have an account. Matched by
/// lowercase email on first sign-in (§4). Tenant-scoped.
model PendingAdminGrant {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  email     String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// Tenant-stamped audit log (§3 #26).
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  userId    String?
  action    String
  target    String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
