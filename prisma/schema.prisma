generator client {
  provider = "prisma-client-js"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     String                 @id @default(cuid())
  clerkId                String                 @unique
  name                   String?
  email                  String?                @unique
  emailVerified          DateTime?
  image                  String?
  coverImage             String?
  bio                    String?
  tagline                String?
  location               String?
  website                String?
  twitter                String?
  linkedin               String?
  github                 String?
  role                   String                 @default("member")
  lastSeen               DateTime               @default(now())
  isOnline               Boolean                @default(false)
  isOnboarded            Boolean                @default(false)
  isBanned               Boolean                @default(false)
  banReason              String?
  bannedAt               DateTime?
  points                 Int                    @default(0)
  level                  Int                    @default(1)
  city                   String?
  importSource           String?
  experienceLevel        String?
  interests              String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  activities             Activity[]
  analyticsEvents        AnalyticsEvent[]
  bookmarks              Bookmark[]
  comments               Comment[]
  connectionsReceived    Connection[]           @relation("ConnectionReceiver")
  connectionsSent        Connection[]           @relation("ConnectionRequester")
  courseEnrollments      CourseEnrollment[]
  digestLogs             DigestLog[]
  emailPreferences       EmailPreference?
  eventRsvps             EventRSVP[]
  eventLumaInterests     EventLumaInterest[]
  lessonProgress         LessonProgress[]
  likes                  Like[]
  mentions               Mention[]
  notifications          Notification[]
  pageViews              PageView[]
  pollVotes              PollVote[]
  posts                  Post[]
  subscriptions          Subscription[]
  userBadges             UserBadge[]
  emailSends             EmailSend[]
  tagAssignments         UserTagAssignment[]
  contactListMemberships ContactListMember[]
  automationEnrollments  AutomationEnrollment[]
  talkSubmissions        TalkSubmission[]
  talkComments           TalkComment[]
  socialAccounts         SocialAccount[]
  socialPosts            SocialPost[]
  tenantMemberships      UserTenant[]
}

/// Role definitions. The user's assigned role is stored both in Clerk
/// `publicMetadata.role` (source of truth for cross-system access) and
/// mirrored to `User.role` for fast lookups inside this app.
model Role {
  name        String
  tenantId    String @default("")
  description String?
  /// JSON-encoded array of Permission strings (see src/lib/permissions.ts).
  /// SQLite has no native JSON column type; we serialize/deserialize at the
  /// service layer.
  permissions String   @default("[]")
  /// System roles (super_admin, admin, member) can't be deleted and have
  /// limited edit semantics in the admin UI.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([tenantId, name])
}

model Badge {
  id          String      @id @default(cuid())
  tenantId    String @default("")
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@unique([tenantId, name])
}

model UserBadge {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, badgeId])
}

/// Home Page CMS — a tenant-editable page. v1 ships only `key = "home"`; the
/// `key` column is the forward seam for additional pages per tenant. `sections`
/// is a JSON string (ordered array of typed blocks) — D1/SQLite has no native
/// JSON column, matching the `TenantSetting.config` precedent.
model Page {
  id        String   @id @default(cuid())
  tenantId  String   @default("")
  key       String // v1: always "home"
  title     String? // optional admin-facing label; not the SEO <title>
  sections  String // JSON string: ordered array of typed blocks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
}

/// Per-tenant city catalog — the runtime replacement for the build-baked
/// `ALL_CITIES` in `src/lib/cities.ts`. Each community curates its own cities
/// (for city landing pages, footer columns, timezone resolution). `keywords` is
/// a JSON string (SEO keyword array); D1/SQLite has no native JSON column,
/// matching the `Page.sections` / `TenantSetting.config` precedent. `position`
/// drives admin-defined ordering.
model City {
  id          String   @id @default(cuid())
  tenantId    String   @default("")
  slug        String
  name        String
  state       String
  stateFull   String
  description String
  isCapital   Boolean  @default(false)
  keywords    String // JSON array string
  timezone    String
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
}

/// Per-tenant industry ("vertical") landing pages served at `/for/<slug>` — the
/// runtime, editable replacement/override for the build-baked `VERTICALS` in
/// `src/lib/verticals.ts`. `data` is a JSON string holding the full `Vertical`
/// shape minus `slug` (the column); D1/SQLite has no native JSON column, matching
/// the `City.keywords` / `Page.sections` precedent. The read layer
/// (`src/lib/industries.ts`) MERGES these over the static built-ins by slug, so a
/// tenant with no rows still gets the region-correct built-ins. `position` drives
/// admin-defined ordering of net-new (non-built-in) pages.
model IndustryPage {
  id        String   @id @default(cuid())
  tenantId  String   @default("")
  slug      String
  data      String // JSON: the Vertical shape minus `slug`
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
}

model SpaceGroup {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  name      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  spaces    Space[]

  @@index([tenantId])
}

model Space {
  id             String          @id @default(cuid())
  tenantId       String @default("")
  name           String
  slug           String
  description    String?
  icon           String?
  color          String?
  isPrivate      Boolean         @default(false)
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  requiredTierId String?
  groupId        String?
  posts          Post[]
  group          SpaceGroup?     @relation(fields: [groupId], references: [id])
  requiredTier   MembershipTier? @relation("TierSpaces", fields: [requiredTierId], references: [id])

  @@unique([tenantId, slug])
}

model Post {
  id          String       @id @default(cuid())
  tenantId    String @default("")
  title       String?
  content     String
  isPinned    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  authorId    String
  spaceId     String
  mediaType   String?
  mediaUrl    String?
  attachments Attachment[]
  bookmarks   Bookmark[]
  comments    Comment[]
  likes       Like[]
  mentions    Mention[]
  poll        Poll?
  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions   Reaction[]

  @@index([tenantId])
}

model Comment {
  id        String            @id @default(cuid())
  tenantId  String @default("")
  content   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  authorId  String
  postId    String
  parentId  String?
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]         @relation("CommentReplies")
  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  @@index([tenantId])
}

model Reaction {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  emoji     String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, postId, emoji])
}

model CommentReaction {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  emoji     String
  userId    String
  commentId String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, commentId, emoji])
}

model Like {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  createdAt DateTime @default(now())
  userId    String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, postId])
}

model Event {
  id                          String              @id @default(cuid())
  tenantId                    String @default("")
  title                       String
  slug                        String?
  description                 String?
  location                    String?
  city                        String?
  timezone                    String? // IANA timezone (e.g. "Australia/Sydney")
  eventType                   String              @default("meetup")
  startTime                   DateTime
  endTime                     DateTime?
  maxAttendees                Int?
  isOnline                    Boolean             @default(false)
  meetingUrl                  String?
  imageUrl                    String?
  lumaUrl                     String? // External Luma event link
  lumaEventId                 String? // Luma event ID for syncing
  rsvpEnabled                 Boolean             @default(false) // Enable internal RSVP when no Luma link is set
  isActive                    Boolean             @default(true) // false = draft, hidden from public listings/pages
  headerText                  String? // Intro paragraph for the generated description
  footerText                  String? // Footer (e.g. "What is X?" + photography disclaimer) for the generated description
  feedbackUrl                 String? // Per-event survey URL used by the post-event email blast
  claudienceSessionCode       String? // Claudience session code (6-char)
  claudienceSessionPassword   String? // Claudience session passcode in cleartext, admin-only
  claudienceSurveyId          String?
  claudienceSurveyUrl         String?
  claudienceSessionUrl        String?
  claudienceNotificationEmail String? // Email to receive feedback survey results
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  rsvps                       EventRSVP[]
  lumaInterests               EventLumaInterest[]
  resources                   EventResource[]
  agendaItems                 EventAgendaItem[]
  speakers                    Speaker[]

  @@unique([tenantId, slug])
}

model EventAgendaItem {
  id           String          @id @default(cuid())
  tenantId     String @default("")
  eventId      String
  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         String // "speaker" | "welcome" | "break" | "custom"
  order        Int // 0-based, dense; rewritten on reorder
  startTime    DateTime?
  endTime      DateTime?
  title        String?
  description  String? // markdown
  speakerId    String?
  speaker      Speaker?        @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   TalkSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId, eventId, order])
  @@index([tenantId, speakerId])
}

// Per-event curated speaker. Source of truth for the slide generator and the
// agenda's speaker slots. Talk title / description live here so a speaker
// carries their talk content across agenda + slide views.
model Speaker {
  id                   String            @id @default(cuid())
  tenantId             String @default("")
  eventId              String
  event                Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  order                Int               @default(0)
  name                 String
  title                String?
  company              String?
  bio                  String? // markdown
  talkTitle            String?
  talkDescription      String? // markdown — long form used in agenda / event pages
  talkDescriptionShort String? // short form (~1 line) shown on speaker slides
  headshotUrl          String?
  companyLogoUrl       String?
  twitterHandle        String?
  linkedinUrl          String?
  websiteUrl           String?
  submissionId         String?
  submission           TalkSubmission?   @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  agendaItems          EventAgendaItem[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([tenantId, eventId, order])
}

model EventResource {
  id          String   @id @default(cuid())
  tenantId    String @default("")
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileUrl     String
  fileName    String
  mimeType    String
  fileSize    Int
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  uploadedBy  String?

  @@index([tenantId, eventId])
}

model EventRSVP {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  status    String   @default("going")
  createdAt DateTime @default(now())
  userId    String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, eventId])
}

// Tracks users who asked to be notified when an event's Luma link is added.
// Once the admin sets the Luma URL we send each waiting user a one-shot
// in-app notification + email; `notifiedAt` makes that idempotent.
model EventLumaInterest {
  id         String    @id @default(cuid())
  tenantId   String @default("")
  userId     String
  eventId    String
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, eventId])
  @@index([tenantId, eventId])
}

model Bookmark {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  createdAt DateTime @default(now())
  userId    String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, postId])
}

model Poll {
  id        String       @id @default(cuid())
  tenantId  String @default("")
  question  String
  endsAt    DateTime?
  createdAt DateTime     @default(now())
  postId    String       @unique
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options   PollOption[]
}

model PollOption {
  id       String     @id @default(cuid())
  tenantId String @default("")
  text     String
  order    Int        @default(0)
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes    PollVote[]

  @@index([tenantId])
}

model PollVote {
  id        String     @id @default(cuid())
  tenantId  String @default("")
  createdAt DateTime   @default(now())
  userId    String
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, optionId])
}

model Attachment {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Mention {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  createdAt DateTime @default(now())
  userId    String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, postId])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  type      String
  data      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model EmailPreference {
  id             String   @id @default(cuid())
  tenantId       String @default("")
  mentions       Boolean  @default(true)
  replies        Boolean  @default(true)
  likes          Boolean  @default(false)
  messages       Boolean  @default(true)
  weeklyDigest   Boolean  @default(true)
  eventReminders Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id             String             @id @default(cuid())
  tenantId       String @default("")
  title          String
  slug           String
  description    String?
  thumbnail      String?
  duration       String?
  difficulty     String             @default("beginner")
  isPublished    Boolean            @default(false)
  isFree         Boolean            @default(true)
  order          Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  requiredTierId String?
  requiredTier   MembershipTier?    @relation(fields: [requiredTierId], references: [id])
  enrollments    CourseEnrollment[]
  lessons        Lesson[]

  @@unique([tenantId, slug])
}

model Lesson {
  id        String           @id @default(cuid())
  tenantId  String @default("")
  title     String
  slug      String
  content   String
  videoUrl  String?
  duration  String?
  order     Int              @default(0)
  isPreview Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  LessonProgress[]

  @@unique([tenantId, courseId, slug])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  tenantId    String @default("")
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, courseId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  tenantId    String @default("")
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  userId      String
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, lessonId])
}

model MembershipTier {
  id            String         @id @default(cuid())
  tenantId      String @default("")
  name          String
  slug          String
  description   String?
  price         Float          @default(0)
  yearlyPrice   Float?
  features      String?
  color         String?
  order         Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  courses       Course[]
  spaces        Space[]        @relation("TierSpaces")
  subscriptions Subscription[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
}

model Subscription {
  id                   String         @id @default(cuid())
  tenantId             String @default("")
  status               String         @default("active")
  interval             String         @default("monthly")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelledAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  userId               String
  tierId               String
  tier                 MembershipTier @relation(fields: [tierId], references: [id])
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, tierId])
}

model PageView {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  event     String
  data      String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model DigestLog {
  id          String   @id @default(cuid())
  tenantId    String @default("")
  sentAt      DateTime @default(now())
  postCount   Int
  eventCount  Int
  memberCount Int
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Connection {
  id          String   @id @default(cuid())
  tenantId    String @default("")
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  requesterId String
  receiverId  String
  receiver    User     @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  requester   User     @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requesterId, receiverId])
}

model LeaderboardLevel {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  level     Int
  name      String
  icon      String?
  minPoints Int
  color     String?
  createdAt DateTime @default(now())

  @@unique([tenantId, level])
}

model EmailCampaign {
  id               String               @id @default(cuid())
  tenantId         String @default("")
  name             String
  subject          String
  html             String
  blocks           String?
  templateType     String               @default("custom")
  status           String               @default("draft")
  segmentQuery     String?
  listId           String?
  previewText      String?
  scheduledAt      DateTime?
  sentAt           DateTime?
  recipientCount   Int                  @default(0)
  sentCount        Int                  @default(0)
  failedCount      Int                  @default(0)
  openCount        Int                  @default(0)
  clickCount       Int                  @default(0)
  bounceCount      Int                  @default(0)
  unsubscribeCount Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sends            EmailSend[]
  list             ContactList?         @relation(fields: [listId], references: [id])
  trackingEvents   EmailTrackingEvent[]
  trackedLinks     EmailTrackedLink[]
  abTest           EmailABTest?

  @@index([tenantId])
}

model EmailSend {
  id               String               @id @default(cuid())
  tenantId         String @default("")
  campaignId       String
  userId           String
  status           String               @default("pending")
  sentAt           DateTime?
  errorMsg         String?
  resendMessageId  String?
  openedAt         DateTime?
  openCount        Int                  @default(0)
  clickedAt        DateTime?
  clickCount       Int                  @default(0)
  deliveredAt      DateTime?
  bouncedAt        DateTime?
  bounceType       String?
  unsubscribeToken String?
  variantId        String?
  createdAt        DateTime             @default(now())
  campaign         EmailCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant          EmailABVariant?      @relation(fields: [variantId], references: [id])
  trackingEvents   EmailTrackingEvent[]

  @@unique([tenantId, campaignId, userId])
  @@unique([tenantId, unsubscribeToken])
}

model EmailSegment {
  id          String   @id @default(cuid())
  tenantId    String @default("")
  name        String
  description String?
  filters     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

