  sponsorshipTypes String // e.g. ["event", "drinks", "catering", "venue", "swag", "data", "prizes", "other"]
  budget           String?
  message          String?
  event            String   @default("melbourne-may-2026")
  status           String   @default("new") // new, contacted, confirmed, declined
  createdAt        DateTime @default(now())
}

// ─── Speaker Slide Generator ────────────────────────────────────────

// Working state for a slide-generator scope: "global" (the admin tool)
// or "event:<eventId>" (per-event tab in the Prepare modal).
// `data` is a JSON blob: { template: SlideTemplate, speakers: SlideSpeaker[], seededIds: string[] }.
model SlideGeneratorState {
  scope     String // "global" or "event:<eventId>"
  tenantId  String @default("")
  data      String // JSON blob
  updatedAt DateTime @updatedAt

  @@id([tenantId, scope])
}

// Named, reusable visual style. Stores only template fields (no speakers).
// Admins save the current look as a named preset, then apply to any event later.
model SlideStylePreset {
  id        String   @id @default(cuid())
  tenantId  String @default("")
  name      String
  data      String // JSON blob of SlideTemplate (visual style only)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
}

// Cache of server-rendered slide PNGs (Cloudflare Browser Rendering output)
// stored in R2 under `slides/render/<contentHash>.png`. One row per
// (eventId, slideId, speakerId) — the unique combo that identifies what's
// being rendered. contentHash is a sha256 over the normalized template +
// speaker fields that actually affect the visual output; when those change
// the renderer writes a new R2 object and overwrites the row, deleting the
// old key.
model SlideRender {
  id          String   @id @default(cuid())
  tenantId    String @default("")
  eventId     String
  slideId     String
  speakerId   String
  contentHash String
  r2Key       String
  mimeType    String   @default("image/png")
  sizeBytes   Int
  renderedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, eventId, slideId, speakerId])
  @@index([tenantId, eventId])
  @@index([tenantId, speakerId])
}

// One row per batch export job submitted to the SlideExportWorkflow. The id
// is the Cloudflare Workflows instance id, so the status route can recover
// the workflow handle. The workflow mutates `completedCount` after each
// rendered pair so the UI sees live progress without polling the workflow
// itself on every tick. `outputKind` is `png` for a single-pair export
// (returned directly) or `zip` for any multi-pair export.
model SlideExportJob {
  id             String   @id // = workflow instance id
  tenantId       String @default("")
  eventId        String
  userId         String
  status         String   @default("queued") // queued | running | complete | errored
  params         String // JSON: { scope, refWidth, force }
  totalCount     Int      @default(0)
  completedCount Int      @default(0)
  outputKind     String? // "png" | "zip"
  outputR2Key    String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, eventId, createdAt])
  @@index([tenantId, userId])
}

