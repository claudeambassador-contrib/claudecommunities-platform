// User-submitted talk idea. May be promoted by an admin to a per-event
// `Speaker`. A single user can submit many talks (returning speakers).
// Fields fall into three groups:
//  - Submitter identity: userId (the signed-in user who owns/edits it),
//    name/email (kept editable for stage-name / contact-email overrides).
//  - Talk content: title (was `topic`), description (long-form),
//    bio (speaker bio for this talk), city (preferred meetup location),
//    slidesUrl + slidesFileName/MimeType/Size (optional deck, can be
//    uploaded before or after the event).
//  - Workflow: status, contentLocked, slidesLocked. The two locks are
//    independent — admins typically lock content after a talk is
//    confirmed/delivered while leaving slides editable so the speaker
//    can post-publish their deck.
model TalkSubmission {
  id             String            @id @default(cuid())
  tenantId       String @default("")
  userId         String?
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  name           String
  email          String
  title          String
  description    String?
  bio            String?
  city           String?
  slidesUrl      String?
  slidesFileName String?
  slidesMimeType String?
  slidesSize     Int?
  status         String            @default("pending")
  contentLocked  Boolean           @default(false)
  slidesLocked   Boolean           @default(false)
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  agendaItems    EventAgendaItem[]
  speakers       Speaker[]
  comments       TalkComment[]

  @@index([tenantId, userId])
}

// Bi-directional thread on a TalkSubmission. Both the submitting user
// and admins post here. No nested replies yet — chronological list.
model TalkComment {
  id           String         @id @default(cuid())
  tenantId     String @default("")
  submissionId String
  submission   TalkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId, submissionId, createdAt])
}

