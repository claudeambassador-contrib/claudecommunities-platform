# .env.cfinfra.example — template for .env.cfinfra (committed, no real values).
#
# Consumed by scripts/gen-wrangler.mjs to render wrangler.jsonc from
# wrangler.template.jsonc:  node scripts/gen-wrangler.mjs --env-file .env.cfinfra
#
# Under Cloudflare Workers Builds these are set per connected environment in
# the dashboard (Settings -> Variables & Secrets) instead of this file.
#
# Fill every key for the deployment(s) you operate. gen-wrangler errors if any
# token used by the template is empty.

# ── Cloudflare account ids ──
CF_ACCOUNT_ID_AU=
CF_ACCOUNT_ID_NZ=

# ── Worker names ──
CF_WORKER_NAME_PROD=
CF_WORKER_NAME_STAGING=
CF_WORKER_NAME_PLATFORM_STAGING=
CF_WORKER_NAME_NZ_PROD=
CF_WORKER_NAME_NZ_STAGING=

# ── D1 primary database ids (DB binding) ──
CF_D1_ID_STAGING=
CF_D1_ID_PROD=
CF_D1_ID_PLATFORM_STAGING=
CF_D1_ID_NZ_PROD=
CF_D1_ID_NZ_STAGING=

# ── D1 tag-cache database ids (NEXT_TAG_CACHE_D1 binding) ──
CF_D1_TAGCACHE_ID_BASE=
CF_D1_TAGCACHE_ID_PROD=
CF_D1_TAGCACHE_ID_STAGING=
CF_D1_TAGCACHE_ID_PLATFORM_STAGING=
CF_D1_TAGCACHE_ID_NZ_PROD=
CF_D1_TAGCACHE_ID_NZ_STAGING=

# ── R2 storage buckets (STORAGE binding) ──
CF_R2_BUCKET_PROD=
CF_R2_BUCKET_STAGING=
CF_R2_BUCKET_PLATFORM_STAGING=
CF_R2_BUCKET_NZ_PROD=
CF_R2_BUCKET_NZ_STAGING=

# ── R2 next-cache buckets (NEXT_INC_CACHE_R2_BUCKET binding) ──
CF_R2_CACHE_BUCKET_PROD=
CF_R2_CACHE_BUCKET_STAGING=
CF_R2_CACHE_BUCKET_PLATFORM_STAGING=
CF_R2_CACHE_BUCKET_NZ_PROD=
CF_R2_CACHE_BUCKET_NZ_STAGING=

# ── Custom-domain routes ──
CF_ROUTE_PROD=
CF_ROUTE_PROD_WWW=
CF_ROUTE_STAGING=
CF_ROUTE_PLATFORM_STAGING=
CF_ROUTE_NZ_PROD=
CF_ROUTE_NZ_STAGING=

# ── Public URLs (NEXT_PUBLIC_APP_URL + NEXT_PUBLIC_SITE_URL) ──
CF_PUBLIC_URL_PROD=
CF_PUBLIC_URL_STAGING=
CF_PUBLIC_URL_PLATFORM_STAGING=
CF_PUBLIC_URL_NZ_PROD=
CF_PUBLIC_URL_NZ_STAGING=
