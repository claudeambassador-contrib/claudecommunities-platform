{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "${CF_WORKER_NAME_PROD}",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Production account = Claude Community (where R2 bucket and D1 database live).
	"account_id": "${CF_ACCOUNT_ID_AU}",
	"observability": {
		"enabled": true
	},
	// Custom domains. These only deploy successfully once `claudecommunity.com.au`
	// is an Active zone on this Cloudflare account (i.e. nameservers swapped from
	// NS1 to Cloudflare). Until then, deploy with `wrangler deploy --routes ""`
	// to skip them, or remove this block.
	"routes": [
		{
			"pattern": "${CF_ROUTE_PROD}",
			"custom_domain": true
		},
		{
			"pattern": "${CF_ROUTE_PROD_WWW}",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"vars": {
		"CLOUDFLARE_WORKER": "true",
		"DEPLOY_TARGET": "cloudflare",
		"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_PROD}",
		"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_PROD}",
		"NEXT_PUBLIC_REGION": "au",
		"CLAUDIENCE_API_URL": "https://claudience.com"
		// Maintenance kill-switch. Set to "true" to take the site offline.
		// Fastest toggle without a full redeploy:
		//   wrangler secret put MAINTENANCE_MODE --env production    (enter "true")
		//   wrangler secret delete MAINTENANCE_MODE --env production (to bring back)
	},
	// Read-side cache bindings (see open-next.config.ts + docs/cloudflare-cpu-optimization.md):
	//   NEXT_INC_CACHE_R2_BUCKET — R2 store for cached page/data payloads.
	//   NEXT_TAG_CACHE_D1        — D1 holding tag→revalidation timestamps for
	//                              on-demand `revalidateTag`/`revalidatePath`.
	//   WORKER_SELF_REFERENCE    — lets the worker re-invoke itself to revalidate.
	// PROVISIONING (run once, then paste the returned ids below):
	//   wrangler r2 bucket create ccau-next-cache
	//   wrangler d1 create ccau-next-tag-cache   → paste database_id into the base + production blocks
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "claudecommunity-db",
			"database_id": "${CF_D1_ID_STAGING}",
			// "remote": true
		},
		{
			"binding": "NEXT_TAG_CACHE_D1",
			"database_name": "ccau-next-tag-cache",
			"database_id": "${CF_D1_TAGCACHE_ID_BASE}"
		}
	],
	"r2_buckets": [
		{
			"binding": "STORAGE",
			"bucket_name": "${CF_R2_BUCKET_PROD}"
		},
		{
			"binding": "NEXT_INC_CACHE_R2_BUCKET",
			"bucket_name": "${CF_R2_CACHE_BUCKET_PROD}"
		}
	],
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "${CF_WORKER_NAME_PROD}"
		}
	],
	// Durable Object queue for ISR background revalidation (see open-next.config.ts).
	// DOQueueHandler is auto-exported by OpenNext's generated worker.js; it's
	// SQLite-backed, so it needs the new_sqlite_classes migration below.
	"durable_objects": {
		"bindings": [
			{
				"name": "NEXT_CACHE_DO_QUEUE",
				"class_name": "DOQueueHandler"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["DOQueueHandler"]
		}
	],
	"browser": {
		"binding": "BROWSER"
	},
	// Cross-service notifications: published to the shared `app-notifications`
	// queue, consumed by the cloudflare-build-notifications worker which routes
	// each message to the right Slack channel by type. See src/lib/notify.ts.
	"queues": {
		"producers": [
			{
				"binding": "NOTIFICATIONS",
				"queue": "app-notifications"
			}
		]
	},
	// Durable workflows:
	//  - slide-export: batch slide export (browser-rendered PNGs + zip → R2).
	//    See src/workflows/slide-export.ts and src/app/api/admin/slide-export/route.ts.
	//  - campaign-send: durable email-campaign send (batches of 100 to Resend,
	//    with 429 backoff + idempotency keys). See src/workflows/campaign-send.ts
	//    and src/app/api/admin/email/campaigns/[id]/send/route.ts.
	"workflows": [
		{
			"name": "slide-export",
			"binding": "SLIDE_EXPORT",
			"class_name": "SlideExportWorkflow"
		},
		{
			"name": "publish-post",
			"binding": "PUBLISH_POST",
			"class_name": "PublishPostWorkflow"
		},
		{
			"name": "campaign-send",
			"binding": "CAMPAIGN_SEND",
			"class_name": "CampaignSendWorkflow"
		}
	],
	// Internal cron triggers. Every 15 minutes the Worker fires `scheduled()`
	// (see scripts/inject-workflow-exports.mjs → src/worker-scheduled.ts)
	// which drains due scheduled posts and resets rows stuck in 'publishing'.
	// Replaces the external pinger that used to hit /api/cron/publish-scheduled-posts.
	"triggers": {
		"crons": ["*/15 * * * *"]
	},
	"env": {
		"production": {
			"name": "${CF_WORKER_NAME_PROD}",
			"account_id": "${CF_ACCOUNT_ID_AU}",
			"routes": [
				{
					"pattern": "${CF_ROUTE_PROD}",
					"custom_domain": true
				}
			],
			"vars": {
				"CLOUDFLARE_WORKER": "true",
				"DEPLOY_TARGET": "cloudflare",
				"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_PROD}",
				"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_PROD}",
				"NEXT_PUBLIC_REGION": "au",
				"CLAUDIENCE_API_URL": "https://claudience.com",
				// Route transactional + campaign email through Send16 (Claude
				// Community workspace, claudecommunity.com.au). Gated by the
				// SEND16_API_KEY secret — unset it (or this var) to revert to Resend.
				"EMAIL_PROVIDER": "send16"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "claudecommunity-db",
					"database_id": "${CF_D1_ID_PROD}"
				},
				{
					"binding": "NEXT_TAG_CACHE_D1",
					"database_name": "ccau-next-tag-cache",
					"database_id": "${CF_D1_TAGCACHE_ID_PROD}"
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "${CF_R2_BUCKET_PROD}"
				},
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "${CF_R2_CACHE_BUCKET_PROD}"
				}
			],
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "${CF_WORKER_NAME_PROD}"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "NEXT_CACHE_DO_QUEUE",
						"class_name": "DOQueueHandler"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["DOQueueHandler"]
				}
			],
			"browser": {
				"binding": "BROWSER"
			},
			"queues": {
				"producers": [
					{
						"binding": "NOTIFICATIONS",
						"queue": "app-notifications"
					}
				]
			},
			"workflows": [
				{
					"name": "slide-export",
					"binding": "SLIDE_EXPORT",
					"class_name": "SlideExportWorkflow"
				},
				{
					"name": "publish-post",
					"binding": "PUBLISH_POST",
					"class_name": "PublishPostWorkflow"
				},
				{
					"name": "campaign-send",
					"binding": "CAMPAIGN_SEND",
					"class_name": "CampaignSendWorkflow"
				}
			],
			"triggers": {
				"crons": ["*/15 * * * *"]
			}
		},
		"staging": {
			"name": "${CF_WORKER_NAME_STAGING}",
			"account_id": "${CF_ACCOUNT_ID_AU}",
			"routes": [
				{
					"pattern": "${CF_ROUTE_STAGING}",
					"custom_domain": true
				}
			],
			"vars": {
				"CLOUDFLARE_WORKER": "true",
				"DEPLOY_TARGET": "cloudflare",
				"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_STAGING}",
				"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_STAGING}",
				"NEXT_PUBLIC_REGION": "au",
				"CLAUDIENCE_API_URL": "https://claudience.com",
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "claudecommunity-db",
					"database_id": "${CF_D1_ID_STAGING}"
				},
				{
					"binding": "NEXT_TAG_CACHE_D1",
					"database_name": "ccau-next-tag-cache-staging",
					"database_id": "${CF_D1_TAGCACHE_ID_STAGING}"
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "${CF_R2_BUCKET_STAGING}"
				},
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "${CF_R2_CACHE_BUCKET_STAGING}"
				}
			],
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "${CF_WORKER_NAME_STAGING}"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "NEXT_CACHE_DO_QUEUE",
						"class_name": "DOQueueHandler"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["DOQueueHandler"]
				}
			],
			"browser": {
				"binding": "BROWSER"
			},
			"queues": {
				"producers": [
					{
						"binding": "NOTIFICATIONS",
						"queue": "app-notifications"
					}
				]
			},
			"workflows": [
				{
					"name": "slide-export-staging",
					"binding": "SLIDE_EXPORT",
					"class_name": "SlideExportWorkflow"
				},
				{
					"name": "publish-post-staging",
					"binding": "PUBLISH_POST",
					"class_name": "PublishPostWorkflow"
				},
				{
					"name": "campaign-send-staging",
					"binding": "CAMPAIGN_SEND",
					"class_name": "CampaignSendWorkflow"
				}
			],
			"triggers": {
				"crons": ["*/15 * * * *"]
			}
		},
		// ─────────────────────────────────────────────────────────────────────
		// PLATFORM STAGING — a NEW, clean multi-tenant SaaS deploy on
		// staging.claudecommunities.com. No AU baggage: its own worker, D1, R2.
		// The apex resolves to the HOME_TENANT ("platform"); real communities are
		// created online via the admin Tenants configurator and reached at
		// staging.claudecommunities.com/<slug> (path-prefix tenancy).
		//
		// BEFORE FIRST DEPLOY, create the resources and paste the ids below:
		//   wrangler d1 create claudecommunity-platform-db-staging
		//   wrangler d1 create ccplatform-next-tag-cache-staging
		//   wrangler r2 bucket create claudecommunity-platform-uploads-staging
		//   wrangler r2 bucket create ccplatform-next-cache-staging
		// Then add staging.claudecommunities.com as a custom domain (needs
		// claudecommunities.com to be an Active zone on this account).
		"staging-platform": {
			"name": "${CF_WORKER_NAME_PLATFORM_STAGING}",
			"account_id": "${CF_ACCOUNT_ID_AU}",
			"routes": [
				{
					"pattern": "${CF_ROUTE_PLATFORM_STAGING}",
					"custom_domain": true
				}
			],
			"vars": {
				"CLOUDFLARE_WORKER": "true",
				"DEPLOY_TARGET": "cloudflare",
				"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_PLATFORM_STAGING}",
				"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_PLATFORM_STAGING}",
				"NEXT_PUBLIC_REGION": "au",
				"CLAUDIENCE_API_URL": "https://claudience.com",
				// The deploy's home tenant — what the apex + /admin resolve to.
				"HOME_TENANT": "platform",
				// Hosts that ARE the platform (apex/local/preview). The default
				// already matches via `.claudecommunities.com`; set explicitly here.
				"PLATFORM_HOSTS": "claudecommunities.com,localhost,127.0.0.1,workers.dev",
				// Subdomain tenancy base = the staging HOST itself, NOT the apex
				// `claudecommunities.com` — otherwise `staging.claudecommunities.com`
				// would be misread as a tenant named "staging" instead of the apex.
				// Path-prefix tenancy (/<slug>) is always on; `*.staging…` subdomain
				// tenancy only activates once a wildcard cert is added.
				"TENANT_SUBDOMAIN_BASES": "staging.claudecommunities.com"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "ccww-staging",
					"database_id": "${CF_D1_ID_PLATFORM_STAGING}"
				},
				{
					"binding": "NEXT_TAG_CACHE_D1",
					"database_name": "ccww-next-cache",
					"database_id": "${CF_D1_TAGCACHE_ID_PLATFORM_STAGING}"
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "${CF_R2_BUCKET_PLATFORM_STAGING}"
				},
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "${CF_R2_CACHE_BUCKET_PLATFORM_STAGING}"
				}
			],
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "${CF_WORKER_NAME_PLATFORM_STAGING}"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "NEXT_CACHE_DO_QUEUE",
						"class_name": "DOQueueHandler"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["DOQueueHandler"]
				}
			],
			"browser": {
				"binding": "BROWSER"
			},
			"queues": {
				"producers": [
					{
						"binding": "NOTIFICATIONS",
						"queue": "app-notifications"
					}
				]
			},
			"workflows": [
				{
					"name": "slide-export-platform-staging",
					"binding": "SLIDE_EXPORT",
					"class_name": "SlideExportWorkflow"
				},
				{
					"name": "publish-post-platform-staging",
					"binding": "PUBLISH_POST",
					"class_name": "PublishPostWorkflow"
				},
				{
					"name": "campaign-send-platform-staging",
					"binding": "CAMPAIGN_SEND",
					"class_name": "CampaignSendWorkflow"
				}
			],
			"triggers": {
				"crons": ["*/15 * * * *"]
			}
		},
		// NZ environments. NZ runs on a SEPARATE Cloudflare account from AU.
		// The placeholders below (account_id, D1 database ids) MUST be filled in
		// once the NZ Cloudflare account + D1 databases actually exist.
		"production-nz": {
			"name": "${CF_WORKER_NAME_NZ_PROD}",
			"account_id": "${CF_ACCOUNT_ID_NZ}",
			"routes": [
				{
					"pattern": "${CF_ROUTE_NZ_PROD}",
					"custom_domain": true
				}
			],
			"vars": {
				"CLOUDFLARE_WORKER": "true",
				"DEPLOY_TARGET": "cloudflare",
				"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_NZ_PROD}",
				"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_NZ_PROD}",
				"NEXT_PUBLIC_REGION": "nz",
				"CLAUDIENCE_API_URL": "https://claudience.com",
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "claudecommunity-nz-db",
					"database_id": "${CF_D1_ID_NZ_PROD}"
				},
				{
					"binding": "NEXT_TAG_CACHE_D1",
					"database_name": "ccnz-next-tag-cache",
					"database_id": "${CF_D1_TAGCACHE_ID_NZ_PROD}"
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "${CF_R2_BUCKET_NZ_PROD}"
				},
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "${CF_R2_CACHE_BUCKET_NZ_PROD}"
				}
			],
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "${CF_WORKER_NAME_NZ_PROD}"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "NEXT_CACHE_DO_QUEUE",
						"class_name": "DOQueueHandler"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["DOQueueHandler"]
				}
			],
			"browser": {
				"binding": "BROWSER"
			},
			"workflows": [
				{
					"name": "slide-export",
					"binding": "SLIDE_EXPORT",
					"class_name": "SlideExportWorkflow"
				},
				{
					"name": "publish-post",
					"binding": "PUBLISH_POST",
					"class_name": "PublishPostWorkflow"
				},
				{
					"name": "campaign-send",
					"binding": "CAMPAIGN_SEND",
					"class_name": "CampaignSendWorkflow"
				}
			],
			"triggers": {
				"crons": ["*/15 * * * *"]
			}
		},
		"staging-nz": {
			"name": "${CF_WORKER_NAME_NZ_STAGING}",
			"account_id": "${CF_ACCOUNT_ID_NZ}",
			"routes": [
				{
					"pattern": "${CF_ROUTE_NZ_STAGING}",
					"custom_domain": true
				}
			],
			"vars": {
				"CLOUDFLARE_WORKER": "true",
				"DEPLOY_TARGET": "cloudflare",
				"NEXT_PUBLIC_APP_URL": "${CF_PUBLIC_URL_NZ_STAGING}",
				"NEXT_PUBLIC_SITE_URL": "${CF_PUBLIC_URL_NZ_STAGING}",
				"NEXT_PUBLIC_REGION": "nz",
				"CLAUDIENCE_API_URL": "https://claudience.com",
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "claudecommunity-nz-db-staging",
					"database_id": "${CF_D1_ID_NZ_STAGING}"
				},
				{
					"binding": "NEXT_TAG_CACHE_D1",
					"database_name": "ccnz-next-tag-cache-staging",
					"database_id": "${CF_D1_TAGCACHE_ID_NZ_STAGING}"
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "${CF_R2_BUCKET_NZ_STAGING}"
				},
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "${CF_R2_CACHE_BUCKET_NZ_STAGING}"
				}
			],
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "${CF_WORKER_NAME_NZ_STAGING}"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "NEXT_CACHE_DO_QUEUE",
						"class_name": "DOQueueHandler"
					}
				]
			},
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["DOQueueHandler"]
				}
			],
			"browser": {
				"binding": "BROWSER"
			},
			"workflows": [
				{
					"name": "slide-export-staging",
					"binding": "SLIDE_EXPORT",
					"class_name": "SlideExportWorkflow"
				},
				{
					"name": "publish-post-staging",
					"binding": "PUBLISH_POST",
					"class_name": "PublishPostWorkflow"
				},
				{
					"name": "campaign-send-staging",
					"binding": "CAMPAIGN_SEND",
					"class_name": "CampaignSendWorkflow"
				}
			],
			"triggers": {
				"crons": ["*/15 * * * *"]
			}
		}
	}
}
