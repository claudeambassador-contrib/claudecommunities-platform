# Build-time env for the PLATFORM staging deploy (staging.claudecommunities.com).
# Copy to `.env.staging.platform` (gitignored) and fill in. Sourced by
# `npm run platform:staging:deploy`. Runtime secrets do NOT go here — set those
# with `wrangler secret put <NAME> --env staging-platform` (see below).

# Home tenant + region. NEXT_PUBLIC_REGION stays a valid Region (au); the apex's
# branding comes from the "platform" tenant's TenantSetting, not the region.
NEXT_PUBLIC_REGION=au
NEXT_PUBLIC_SITE_URL=https://staging.claudecommunities.com
NEXT_PUBLIC_APP_URL=https://staging.claudecommunities.com

# Clerk (the platform's OWN Clerk instance — a dummy key renders public pages but
# auth/login will NOT work). Publishable key is build-time; secret is a Worker
# secret (set via wrangler, not here).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional build-time:
NEXT_PUBLIC_GA_ID=
RESEND_FROM_EMAIL=

# ── Worker SECRETS — do NOT put values here; set with wrangler ───────────────
#   wrangler secret put CLERK_SECRET_KEY          --env staging-platform
#   wrangler secret put CLERK_JWT_ISSUER_DOMAIN   --env staging-platform
#   wrangler secret put RENDER_SIGNING_SECRET     --env staging-platform
#   wrangler secret put CRON_SECRET               --env staging-platform
#   wrangler secret put SOCIAL_OAUTH_STATE_SECRET --env staging-platform
#   wrangler secret put RESEND_API_KEY            --env staging-platform   # if email used
