# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.*.example

# One-shot Neon → D1 migration output (per-run, contains user IDs)
/migrations/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
nul
*.db
*.db-journal

DATABASE.md

# Cloudflare / OpenNext
.open-next
.wrangler
.dev.vars
# Generated by scripts/gen-wrangler.mjs from wrangler.template.jsonc + .env.cfinfra
# (build artifact — never committed; carries per-deployment account/resource ids).
wrangler.jsonc

# Claude Code
.claude/worktrees

# mcp-ui generated artifacts
/mcp-ui/dist/
/mcp-ui/node_modules/
/src/lib/mcp/ui-bundle.generated.ts

# clerk configuration (can include secrets)
/.clerk/

# Multi-tenant isolation test artifacts
test/iso/.schema.sql

# Generated per-region tenant seed (scripts/seed-tenant.ts -> *:d1:seed-tenant)
scripts/.tenant-seed.sql
# Generated tenant provisioning SQL (scripts/provision-tenant.ts -> local:tenant:provision)
scripts/.tenant-provision.sql
# Generated platform home-tenant seed (scripts/seed-platform.ts -> platform:staging:seed-admin)
scripts/.platform-seed.sql

# Phase-0 multi-tenancy W4P spike (throwaway prototype, generated bundles)
spike/

# Transient Workflow scripts
scripts/.wf-*.mjs

# mobile (Capacitor/Android) — local-only experiment. Build output is huge
# (~190MB) and mobile/android/android.keystore is a signing secret. PWA-first
# is the chosen direction; nothing here belongs in the repo for now.
/mobile/
